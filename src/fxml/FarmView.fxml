<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>

<HBox fx:id="farmView" spacing="0"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.FarmController"
    style="-fx-background-color: #1a1208;">

    <!-- ── Grille de culture ── -->
    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
        style="-fx-background-color: radial-gradient(center 50% 50%, radius 80%, #2a1f0e, #1a1208);
               -fx-padding: 20;">
        <Label text="🌿  CHAMPS"
            style="-fx-text-fill: #c8860a; -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-font-family: 'Georgia'; -fx-padding: 0 0 12 0;"/>
        <GridPane fx:id="farmGrid" alignment="CENTER" hgap="3" vgap="3"
            style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 12;
                   -fx-border-color: #5a3a1a; -fx-border-radius: 12; -fx-border-width: 2;
                   -fx-padding: 10;"/>
    </VBox>

    <!-- ── Panneau animaux ── -->
    <VBox fx:id="animalBox" prefWidth="260" spacing="10"
        style="-fx-background-color: linear-gradient(to bottom, #1e140a, #2c1a0e);
               -fx-padding: 16; -fx-border-color: #c8860a; -fx-border-width: 0 0 0 2;">
        <Label text="🐾  ANIMAUX"
            style="-fx-text-fill: #c8860a; -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-font-family: 'Georgia'; -fx-padding: 0 0 8 0;"/>
    </VBox>

</HBox>
