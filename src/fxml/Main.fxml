<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>

<BorderPane prefHeight="750.0" prefWidth="1100.0"
    style="-fx-background-color: #1a1208;"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.MainController">

    <!-- ══════════════════════  HEADER  ══════════════════════ -->
    <top>
        <VBox style="-fx-background-color: linear-gradient(to bottom, #2c1a0e, #1a1208);
                     -fx-border-color: #c8860a; -fx-border-width: 0 0 3 0;
                     -fx-padding: 12 24 12 24;
                     -fx-effect: dropshadow(gaussian, #000, 12, 0.5, 0, 4);">
            <HBox spacing="0" alignment="CENTER_LEFT">

                <!-- Logo -->
                <Label text="🌾 FARM MY FARM"
                    style="-fx-text-fill: #f5c842; -fx-font-size: 22px; -fx-font-weight: bold;
                           -fx-font-family: 'Georgia';
                           -fx-effect: dropshadow(gaussian, #000, 6, 0.8, 1, 1);"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Argent -->
                <HBox alignment="CENTER" spacing="6"
                    style="-fx-background-color: rgba(0,0,0,0.4); -fx-background-radius: 20;
                           -fx-border-color: #c8860a; -fx-border-radius: 20; -fx-border-width: 1.5;
                           -fx-padding: 6 16 6 16;">
                    <Label text="💰" style="-fx-font-size: 16px;"/>
                    <Label fx:id="moneyLabel"
                        style="-fx-text-fill: #f5c842; -fx-font-size: 15px; -fx-font-weight: bold;
                               -fx-font-family: 'Georgia';"/>
                </HBox>

                <Region prefWidth="12"/>

                <!-- Graine équipée -->
                <HBox alignment="CENTER" spacing="6"
                    style="-fx-background-color: rgba(0,0,0,0.3); -fx-background-radius: 20;
                           -fx-border-color: #7cb87c; -fx-border-radius: 20; -fx-border-width: 1.5;
                           -fx-padding: 6 16 6 16;">
                    <Label text="🌱" style="-fx-font-size: 14px;"/>
                    <Label fx:id="seedLabel"
                        style="-fx-text-fill: #a8e6a8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>

                <Region prefWidth="20"/>

                <!-- Boutons nav -->
                <HBox spacing="8" alignment="CENTER">
                    <Button onAction="#showFarm" text="🏡  MA FERME"
                        style="-fx-background-color: #5a3a1a; -fx-text-fill: #f5c842;
                               -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Georgia';
                               -fx-background-radius: 8; -fx-border-color: #c8860a;
                               -fx-border-radius: 8; -fx-border-width: 1.5;
                               -fx-padding: 8 20; -fx-cursor: hand;"/>
                    <Button onAction="#showMarket" text="🛒  MARCHÉ"
                        style="-fx-background-color: #1a3a1a; -fx-text-fill: #7cb87c;
                               -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Georgia';
                               -fx-background-radius: 8; -fx-border-color: #4a8a4a;
                               -fx-border-radius: 8; -fx-border-width: 1.5;
                               -fx-padding: 8 20; -fx-cursor: hand;"/>
                </HBox>

                <Region prefWidth="20"/>
                <Separator orientation="VERTICAL" style="-fx-background-color: #5a3a1a;"/>
                <Region prefWidth="12"/>

                <!-- Boutons Save / Load -->
                <HBox spacing="8" alignment="CENTER">
                    <Button onAction="#saveGame" text="💾  SAUVER"
                        style="-fx-background-color: #1a2a3a; -fx-text-fill: #7ab8f5;
                               -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Georgia';
                               -fx-background-radius: 8; -fx-border-color: #3a6a9a;
                               -fx-border-radius: 8; -fx-border-width: 1.5;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <Button onAction="#loadGame" text="📂  CHARGER"
                        style="-fx-background-color: #2a1a3a; -fx-text-fill: #c8a8f5;
                               -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Georgia';
                               -fx-background-radius: 8; -fx-border-color: #6a3a9a;
                               -fx-border-radius: 8; -fx-border-width: 1.5;
                               -fx-padding: 8 16; -fx-cursor: hand;"/>
                    <!-- Statut discret -->
                    <Label fx:id="saveStatusLabel" text=""
                        style="-fx-text-fill: #6a8a6a; -fx-font-size: 11px; -fx-font-family: 'Georgia';"/>
                </HBox>

            </HBox>
        </VBox>
    </top>

    <!-- ══════════════════════  CENTRE  ══════════════════════ -->
    <center>
        <StackPane style="-fx-background-color: #1a1208;">
            <fx:include fx:id="farmView" source="FarmView.fxml" />
            <fx:include fx:id="marketView" source="MarketView.fxml" />
        </StackPane>
    </center>

    <!-- ══════════════════════  INVENTAIRE BAS  ══════════════════════ -->
    <bottom>
        <HBox alignment="CENTER" spacing="30"
            style="-fx-background-color: linear-gradient(to top, #2c1a0e, #1a1208);
                   -fx-padding: 12 24 12 24;
                   -fx-border-color: #c8860a; -fx-border-width: 3 0 0 0;
                   -fx-effect: dropshadow(gaussian, #000, 10, 0.5, 0, -3);">

            <!-- GRAINES -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="▸ GRAINES"
                    style="-fx-text-fill: #c8860a; -fx-font-weight: bold; -fx-font-size: 11px;
                           -fx-font-family: 'Georgia';"/>
                <HBox spacing="10" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(255,200,50,0.08); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 12;">
                        <Button onAction="#equipWheat" text="🌾 Blé"
                            style="-fx-background-color: transparent; -fx-text-fill: #f5e6a0;
                                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 2 6;"/>
                        <Label fx:id="wheatSeedQty" text="x0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(255,200,50,0.08); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 12;">
                        <Button onAction="#equipCorn" text="🌽 Maïs"
                            style="-fx-background-color: transparent; -fx-text-fill: #f5e6a0;
                                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 2 6;"/>
                        <Label fx:id="cornSeedQty" text="x0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(255,200,50,0.08); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 12;">
                        <Button onAction="#equipCarrot" text="🥕 Carotte"
                            style="-fx-background-color: transparent; -fx-text-fill: #f5e6a0;
                                   -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 2 6;"/>
                        <Label fx:id="carrotSeedQty" text="x0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #5a3a1a;"/>

            <!-- NOURRITURE -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="▸ RÉSERVES"
                    style="-fx-text-fill: #c8860a; -fx-font-weight: bold; -fx-font-size: 11px;
                           -fx-font-family: 'Georgia';"/>
                <HBox spacing="10" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(100,180,100,0.08); -fx-background-radius: 8;
                               -fx-border-color: #2a4a2a; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🌾" style="-fx-font-size: 16px;"/>
                        <Label fx:id="wheatFoodQty" text="0"
                            style="-fx-text-fill: #a8e6a8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(100,180,100,0.08); -fx-background-radius: 8;
                               -fx-border-color: #2a4a2a; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🌽" style="-fx-font-size: 16px;"/>
                        <Label fx:id="cornFoodQty" text="0"
                            style="-fx-text-fill: #a8e6a8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(100,180,100,0.08); -fx-background-radius: 8;
                               -fx-border-color: #2a4a2a; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🥕" style="-fx-font-size: 16px;"/>
                        <Label fx:id="carrotFoodQty" text="0"
                            style="-fx-text-fill: #a8e6a8; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>

            <Separator orientation="VERTICAL" style="-fx-background-color: #5a3a1a;"/>

            <!-- PRODUITS -->
            <VBox spacing="6" alignment="CENTER">
                <Label text="▸ PRODUITS"
                    style="-fx-text-fill: #c8860a; -fx-font-weight: bold; -fx-font-size: 11px;
                           -fx-font-family: 'Georgia';"/>
                <HBox spacing="10" alignment="CENTER">
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(200,134,10,0.1); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🥛" style="-fx-font-size: 16px;"/>
                        <Label fx:id="milkQty" text="0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(200,134,10,0.1); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🥚" style="-fx-font-size: 16px;"/>
                        <Label fx:id="eggQty" text="0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox alignment="CENTER" spacing="3"
                        style="-fx-background-color: rgba(200,134,10,0.1); -fx-background-radius: 8;
                               -fx-border-color: #5a4020; -fx-border-radius: 8; -fx-padding: 6 14;">
                        <Label text="🥓" style="-fx-font-size: 16px;"/>
                        <Label fx:id="baconQty" text="0"
                            style="-fx-text-fill: #f5c842; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>

        </HBox>
    </bottom>

</BorderPane>
