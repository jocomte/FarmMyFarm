<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<BorderPane prefHeight="900.0" prefWidth="1200.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">
    <top>
        <VBox style="-fx-background-color: #3e2723; -fx-padding: 15;">
            <HBox spacing="20">
                <Label fx:id="moneyLabel" textFill="YELLOW" />
                <Label fx:id="seedLabel" textFill="WHITE" />
                <Button onAction="#showFarm" text="MA FERME" />
                <Button onAction="#showMarket" text="MARCHÉ" />
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <fx:include fx:id="farmView" source="FarmView.fxml" />
            <fx:include fx:id="marketView" source="MarketView.fxml" />
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="40" style="-fx-background-color: #2e1a1a; -fx-padding: 15; -fx-border-color: #5d4037; -fx-border-width: 4 0 0 0;">
            <VBox spacing="5" alignment="CENTER">
                <Label text="ÉQUIPER GRAINE" textFill="#aaa" style="-fx-font-weight: bold;" />
                <HBox spacing="15">
                    <Button onAction="#equipWheat" text="Blé" /><Label fx:id="wheatSeedQty" text="x0" textFill="WHITE" />
                    <Button onAction="#equipCorn" text="Maïs" /><Label fx:id="cornSeedQty" text="x0" textFill="WHITE" />
                    <Button onAction="#equipCarrot" text="Carotte" /><Label fx:id="carrotSeedQty" text="x0" textFill="WHITE" />
                </HBox>
            </VBox>
            <Separator orientation="VERTICAL" />
            <VBox spacing="5" alignment="CENTER">
                <Label text="RÉSERVES NOURRITURE" textFill="#aaa" style="-fx-font-weight: bold;" />
                <HBox spacing="20">
                    <Label fx:id="wheatFoodQty" text="Blé: 0" textFill="#ffd700" />
                    <Label fx:id="cornFoodQty" text="Maïs: 0" textFill="#ffd700" />
                    <Label fx:id="carrotFoodQty" text="Carotte: 0" textFill="#ffd700" />
                </HBox>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>