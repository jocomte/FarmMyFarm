<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox fx:id="marketView" alignment="TOP_CENTER" spacing="20"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="controller.MarketController"
    style="-fx-background-color: #1a1208; -fx-padding: 30 60 30 60;">

    <Label text="🛒  MARCHÉ DU VILLAGE"
        style="-fx-text-fill: #f5c842; -fx-font-size: 26px; -fx-font-weight: bold;
               -fx-font-family: 'Georgia'; -fx-effect: dropshadow(gaussian, #000, 8, 0.6, 1, 2);"/>

    <Label text="Achetez des graines, des animaux, et vendez vos récoltes."
        style="-fx-text-fill: #8a7060; -fx-font-size: 12px; -fx-font-family: 'Georgia';"/>

    <Separator style="-fx-background-color: #5a3a1a;"/>

    <VBox spacing="12">
        <Label text="▸  ACHETER"
            style="-fx-text-fill: #c8860a; -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-font-family: 'Georgia';"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Graines"
                style="-fx-text-fill: #8a9a70; -fx-font-size: 12px; -fx-min-width: 80;"/>
            <Button text="🌾  Blé  —  10 $" onAction="#buyWheat"
                style="-fx-background-color: #2a3a1a; -fx-text-fill: #a8d880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #4a6a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🌽  Maïs  —  30 $" onAction="#buyCorn"
                style="-fx-background-color: #2a3a1a; -fx-text-fill: #a8d880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #4a6a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🥕  Carotte  —  60 $" onAction="#buyCarott"
                style="-fx-background-color: #2a3a1a; -fx-text-fill: #a8d880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #4a6a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Animaux"
                style="-fx-text-fill: #8a9a70; -fx-font-size: 12px; -fx-min-width: 80;"/>
            <Button text="🐔  Poule  —  50 $" onAction="#buyChicken"
                style="-fx-background-color: #3a2a10; -fx-text-fill: #f5d890;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #7a5a20;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🐄  Vache  —  150 $" onAction="#buyCow"
                style="-fx-background-color: #3a2a10; -fx-text-fill: #f5d890;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #7a5a20;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🐖  Cochon  —  300 $" onAction="#buyPig"
                style="-fx-background-color: #3a2a10; -fx-text-fill: #f5d890;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #7a5a20;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <Separator style="-fx-background-color: #5a3a1a;"/>

    <VBox spacing="12">
        <Label text="▸  VENDRE"
            style="-fx-text-fill: #c8860a; -fx-font-size: 14px; -fx-font-weight: bold;
                   -fx-font-family: 'Georgia';"/>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Récoltes"
                style="-fx-text-fill: #8a9a70; -fx-font-size: 12px; -fx-min-width: 80;"/>
            <Button text="🌾  Blé  —  25 $/u" onAction="#sellWheat"
                style="-fx-background-color: #3a1a00; -fx-text-fill: #ffb74d;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #c8600a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🌽  Maïs  —  60 $/u" onAction="#sellCorn"
                style="-fx-background-color: #3a1a00; -fx-text-fill: #ffb74d;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #c8600a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🥕  Carotte  —  120 $/u" onAction="#sellCarrot"
                style="-fx-background-color: #3a1a00; -fx-text-fill: #ffb74d;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #c8600a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Produits"
                style="-fx-text-fill: #8a9a70; -fx-font-size: 12px; -fx-min-width: 80;"/>
            <Button text="🥚  Œufs  —  40 $/u" onAction="#sellEgg"
                style="-fx-background-color: #1a3a1a; -fx-text-fill: #80e880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #2a8a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🥛  Lait  —  80 $/u" onAction="#sellMilk"
                style="-fx-background-color: #1a3a1a; -fx-text-fill: #80e880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #2a8a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
            <Button text="🥓  Bacon  —  150 $/u" onAction="#sellBacon"
                style="-fx-background-color: #1a3a1a; -fx-text-fill: #80e880;
                       -fx-font-weight: bold; -fx-font-size: 12px;
                       -fx-background-radius: 8; -fx-border-color: #2a8a2a;
                       -fx-border-radius: 8; -fx-padding: 8 18; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</VBox>
